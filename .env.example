# -----------------------------
# Application
# -----------------------------
APP_ENV=production
APP_NAME=AI Support Agent
APP_SECRET_KEY=replace_with_a_long_random_secret
DEBUG=false

# -----------------------------
# Dashboard
# -----------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# -----------------------------
# PostgreSQL
# Do not put real passwords in this file.
# -----------------------------
POSTGRES_DB=ai_support
POSTGRES_USER=ai_support_user
POSTGRES_PASSWORD=replace_with_strong_database_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql://ai_support_user:replace_with_strong_database_password@postgres:5432/ai_support

# -----------------------------
# Redis
# -----------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# -----------------------------
# JWT Authentication
# -----------------------------
JWT_SECRET_KEY=replace_with_a_different_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# -----------------------------
# Meta WhatsApp Cloud API
# -----------------------------
META_ACCESS_TOKEN=replace_with_meta_access_token
VERIFY_TOKEN=replace_with_webhook_verify_token
META_GRAPH_API_VERSION=v23.0

# -----------------------------
# Public URLs
# Replace with your real domain later.
# -----------------------------
PUBLIC_BASE_URL=https://yourdomain.com
DASHBOARD_URL=https://yourdomain.com
WHATSAPP_WEBHOOK_URL=https://yourdomain.com/webhook

# -----------------------------
# Logging
# -----------------------------
LOG_LEVEL=INFO

GEMINI_API_KEY=